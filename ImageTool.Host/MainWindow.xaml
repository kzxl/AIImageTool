<Window x:Class="ImageTool.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Studio" Height="600" Width="900" Background="#1E1E1E">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#252526" BorderBrush="#333" BorderThickness="0,0,1,0">
            <ListBox x:Name="lstPlugins" Background="Transparent" BorderThickness="0" 
                     Foreground="White" SelectionChanged="LstPlugins_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" Padding="10,5" FontSize="14" Cursor="Hand" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Main Content (Plugin UI) -->
        <ContentControl x:Name="contentPresenter" Grid.Column="1" />
    </Grid>
</Window>
