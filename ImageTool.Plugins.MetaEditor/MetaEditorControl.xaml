<UserControl x:Class="ImageTool.Plugins.MetaEditor.MetaEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Metadata Editor (EXIF Info)" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Drop and Preview Area -->
            <Border x:Name="borderImageArea" Grid.Column="0" BorderBrush="#555" BorderThickness="2" CornerRadius="8" 
                    Background="#2A2A2A" AllowDrop="True" Drop="Border_Drop" MouseLeftButtonDown="Border_MouseLeftButtonDown" Cursor="Hand" Margin="0,0,10,0">
                <Grid>
                    <TextBlock x:Name="txtPrompt" Text="Nhập chuột hoặc Kéo thả ảnh vào đây để xem MetaData" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#888" FontSize="18" Panel.ZIndex="10"/>
                    <Image x:Name="imgPreview" Stretch="Uniform" Margin="10"/>
                    <Button x:Name="btnClearImage" Content="✕ Bỏ chọn ảnh" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Padding="15,5" 
                            Background="#AA000000" Foreground="White" BorderThickness="0" Cursor="Hand" Visibility="Collapsed" Click="BtnClearImage_Click" Panel.ZIndex="20">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <!-- Metadata Info Area -->
            <Border x:Name="pnlMeta" Grid.Column="1" Background="#252526" BorderBrush="#444" BorderThickness="1" CornerRadius="8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="15,15,15,10">
                        <TextBlock Text="Thông tin Meta (EXIF)" FontSize="16" FontWeight="SemiBold" Foreground="#E0E0E0" Margin="0,0,0,5"/>
                        <TextBlock Text="Hỗ trợ sửa: Software, ImageDescription, Make, Model, Artist, Copyright" FontSize="11" Foreground="#888" TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <Button x:Name="btnSaveMeta" DockPanel.Dock="Bottom" Content="Lưu Thay Đổi Meta" Height="38" Margin="15" Background="#1E6E43" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnSaveMeta_Click" IsEnabled="False">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    
                    <DataGrid x:Name="dgMeta" AutoGenerateColumns="False" Margin="15,0,15,0"
                              CanUserAddRows="False" Background="Transparent" Foreground="#CCC" RowBackground="#333" AlternatingRowBackground="#3A3A3A" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#555" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Thuộc tính" Binding="{Binding Name}" IsReadOnly="True" Width="120"/>
                            <DataGridTextColumn Header="Giá trị" Binding="{Binding Value}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
