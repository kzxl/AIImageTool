<UserControl x:Class="ImageTool.Plugins.Upscaler.UpscalerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="AI Image Upscaler" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Drag Drop Area / Image Preview -->
        <Border x:Name="borderImageArea" Grid.Row="1" BorderBrush="#555" BorderThickness="2" CornerRadius="8" 
                Background="#2A2A2A" AllowDrop="True" Drop="Border_Drop" MouseLeftButtonDown="Border_MouseLeftButtonDown" Cursor="Hand" Margin="0,0,0,20">
            <Grid x:Name="gridImageContainer" SizeChanged="GridImageContainer_SizeChanged"
                  Background="Transparent"
                  MouseLeftButtonDown="GridImageContainer_MouseLeftButtonDown"
                  MouseMove="GridImageContainer_MouseMove"
                  MouseLeftButtonUp="GridImageContainer_MouseLeftButtonUp"
                  MouseLeave="GridImageContainer_MouseLeave">
                <TextBlock x:Name="txtPrompt" Text="Nhập chuột hoặc Kéo thả ảnh vào đây" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#888" FontSize="18" Panel.ZIndex="10"/>
                
                <Image x:Name="imgOriginal" Stretch="Uniform" Margin="10"/>
                <Image x:Name="imgPreview" Stretch="Uniform" Margin="10"/>
                
                <Border x:Name="borderSplitLine" Width="2" Background="White" HorizontalAlignment="Left" Visibility="Collapsed" IsHitTestVisible="False">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>
                </Border>

                <Button x:Name="btnClearImage" Content="✕ Bỏ chọn ảnh" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Padding="15,5" 
                        Background="#AA000000" Foreground="White" BorderThickness="0" Cursor="Hand" Visibility="Collapsed" Click="BtnClearImage_Click" Panel.ZIndex="20">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- Controls -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock x:Name="txtStatus" Text="Sẵn sàng" Foreground="#AAA" FontWeight="Medium"/>
                    <TextBlock x:Name="txtExecMode" Text="[Nhận diện cấu trúc...]" Foreground="#55C1E7" FontStyle="Italic" Margin="10,0,0,0"/>
                </StackPanel>
                <ProgressBar x:Name="pbProgress" Height="8" Minimum="0" Maximum="100" Value="0" Visibility="Hidden" Foreground="#007ACC" Background="#444" BorderThickness="0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <ComboBox x:Name="cmbDevice" Width="160" Margin="0,0,10,0" SelectedIndex="0" VerticalContentAlignment="Center" ToolTip="Thiết bị thực thi (GPU/CPU)" DisplayMemberPath="Name" />
                <ComboBox x:Name="cmbPerformance" Width="100" Margin="0,0,10,0" SelectedIndex="0" VerticalContentAlignment="Center" ToolTip="Mức độ hiệu năng hệ thống">
                    <ComboBoxItem Content="An toàn" Tag="Safe" />
                    <ComboBoxItem Content="Bung lụa" Tag="Unleashed" />
                </ComboBox>
                <ComboBox x:Name="cmbModel" Width="160" Margin="0,0,10,0" SelectedIndex="0" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="UltraSharp V2 (Cục bộ)"/>
                    <ComboBoxItem Content="AuraSR (Generative API)"/>
                </ComboBox>
                <ComboBox x:Name="cmbScale" Width="55" Margin="0,0,10,0" SelectedIndex="1" VerticalContentAlignment="Center" ToolTip="Tỷ lệ phóng to (x2 mặc định thu nhỏ nét hơn, x8 dùng nội suy)">
                    <ComboBoxItem Content="x2" Tag="2"/>
                    <ComboBoxItem Content="x4" Tag="4"/>
                    <ComboBoxItem Content="x8" Tag="8"/>
                </ComboBox>
                <Button x:Name="btnProcess" Content="Upscale" Width="100" Height="35" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnProcess_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
