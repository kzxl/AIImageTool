<UserControl x:Class="ImageTool.Plugins.Upscaler.UpscalerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="AI Image Upscaler" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Drag Drop Area / Image Preview -->
        <Border Grid.Row="1" BorderBrush="#555" BorderThickness="2" CornerRadius="8" 
                Background="#2A2A2A" AllowDrop="True" Drop="Border_Drop" Margin="0,0,0,20">
            <Grid>
                <TextBlock x:Name="txtPrompt" Text="Drag &amp; Drop Image Here" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#888" FontSize="18"/>
                <Image x:Name="imgPreview" Stretch="Uniform" Margin="10"/>
            </Grid>
        </Border>

        <!-- Controls -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                <TextBlock x:Name="txtStatus" Text="Sẵn sàng" Foreground="#AAA" Margin="0,0,0,5" FontWeight="Medium"/>
                <ProgressBar x:Name="pbProgress" Height="8" Minimum="0" Maximum="100" Value="0" Visibility="Hidden" Foreground="#007ACC" Background="#444" BorderThickness="0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <ComboBox x:Name="cmbModel" Width="150" Margin="0,0,10,0" SelectedIndex="0">
                    <ComboBoxItem Content="ESRGAN (4x)"/>
                </ComboBox>
                <Button x:Name="btnProcess" Content="Upscale" Width="100" Height="35" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnProcess_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
